{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile Current Java Folder",
      "type": "shell",
      "command": "/bin/bash",
      "args": [
        "-lc",
        "set -e; out=\"${fileDirname}/.vscode-bin\"; mkdir -p \"$out\"; /usr/local/sdkman/candidates/java/25.0.1-ms/bin/javac -d \"$out\" \"${fileDirname}\"/*.java"
      ],
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Compile Root Main",
      "type": "shell",
      "command": "/usr/local/sdkman/candidates/java/25.0.1-ms/bin/javac",
      "args": [
        "-d",
        "${workspaceFolder}/.vscode/bin",
        "${workspaceFolder}/Main.java"
      ],
      "group": "build",
      "problemMatcher": [
        "$javac"
      ]
    }
  ]
}
